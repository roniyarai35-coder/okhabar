//#################### PROFILE CANDIDATE CAROUSEL##
//##################################################
document.querySelectorAll(".okel-carousel-container").forEach((container) => {
  const track = container.querySelector(".carousel-track");
  const prevBtn = container.querySelector(".prev-btn");
  const nextBtn = container.querySelector(".next-btn");
  const items = container.querySelectorAll(".carousel-item");

  // Get visibleItems from data attribute, default to 4 if not specified
  const visibleItems = Number(container.dataset.visibleItems) || 4;

  let currentIndex = 0;
  const totalItems = items.length;
  const maxIndex = totalItems - visibleItems;

  function updateCarousel() {
    const gap = 20;

    // Correct calculation: subtract total gap space from 100%, then divide
    items.forEach((item) => {
      item.style.width = `calc((100% - ${(visibleItems - 1) * gap}px) / ${visibleItems})`;
    });

    if (!items.length) {
      return;
    }

    const itemWidth = items[0].offsetWidth;
    const offset = currentIndex * (itemWidth + gap);
    track.style.transform = `translateX(-${offset}px)`;
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex >= maxIndex;
  }

  prevBtn.addEventListener("click", () => {
    if (currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    }
  });

  nextBtn.addEventListener("click", () => {
    if (currentIndex < maxIndex) {
      currentIndex++;
      updateCarousel();
    }
  });

  window.addEventListener("resize", updateCarousel);
  updateCarousel();
});
//#################### END PROFILE CANDIDATE CAROUSEL##
//##################################################

//################# FUnction onclick scroll to ID###
//################# FUnction onclick scroll to ID###
function scrollToSection(id, offset = 0) {
  const el = document.getElementById(id);
  if (!el) return;
  const y = el.getBoundingClientRect().top + window.pageYOffset - offset;
  window.scrollTo({
    top: y,
    behavior: "smooth",
  });
}

const quickNavItem = document.querySelectorAll(".quickItem");
quickNavItem.forEach((item) => {
  item.addEventListener("click", function () {
    quickNavItem.forEach((i) => i.classList.remove("active"));
    this.classList.add("active");
  });
});

